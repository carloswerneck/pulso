PORT=3000
NODE_ENV=production

# Caminho do banco SQLite (montar como volume persistente no Easypanel)
DB_PATH=./data/pressao.db

# Autenticação do dashboard
AUTH_USER=admin
AUTH_PASSWORD_HASH=<gerar com bcrypt, ver README>

# Chave de sessão (string aleatória longa)
SESSION_SECRET=<gerar string aleatória>

# API key para chamadas externas (n8n)
API_KEY=<gerar string aleatória>

# Opcional: nome do paciente, aparece no cabeçalho do PDF
PACIENTE_NOME=

# Token para link público do relatório (gere com openssl rand -hex 16)
# Deixe vazio para desabilitar o link público
PUBLIC_TOKEN=
